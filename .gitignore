# Local .terraform directories
**/.terraform/*

# .tfstate files (never commit state; use S3 backend)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# .tfvars files often contain sensitive data
*.tfvars
*.tfvars.json
!example.tfvars

# Override files for customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output
*.tfplan
plan.out

# CLI configuration
.terraformrc
terraform.rc

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
